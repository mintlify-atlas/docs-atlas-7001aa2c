{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ZOODOM",
  "theme": "almond",
  "colors": {
    "primary": "#51B063",
    "light": "#ACFFBC",
    "dark": "#246C32"
  },
  "favicon": "https://media.brand.dev/4abad5ad-7194-4574-8337-cbc9e8b87ece.png",
  "logo": {
    "light": "https://media.brand.dev/e570d5d0-15ad-4994-a6d1-093679736eb0.svg",
    "dark": "https://media.brand.dev/e570d5d0-15ad-4994-a6d1-093679736eb0.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Iceheop/zoodom"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Iceheop/zoodom"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "installation"]
          },
          {
            "group": "Project Structure",
            "pages": ["structure/overview", "structure/pages", "structure/components", "structure/layouts", "structure/assets"]
          },
          {
            "group": "Features",
            "pages": ["features/homepage", "features/species-catalog", "features/event-calendar", "features/visit-planning", "features/blog", "features/gallery"]
          },
          {
            "group": "Styling",
            "pages": ["styling/design-system", "styling/colors", "styling/typography", "styling/bootstrap-integration"]
          },
          {
            "group": "Development",
            "pages": ["development/local-setup", "development/building", "development/deployment"]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Core Components",
            "pages": ["components/head", "components/layout"]
          },
          {
            "group": "Navigation",
            "pages": ["components/navbar"]
          }
        ]
      }
    ]
  }
}
